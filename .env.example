# ========================================
# 🔐 Configuration Password Manager
# ========================================
# Copiez ce fichier en .env puis renseignez de VRAIES valeurs.
# Ne committez JAMAIS le fichier .env (il est ignoré par git).
# Générez les secrets avec : python -c "import secrets; print(secrets.token_urlsafe(48))"

# ----------------------------------------
# 🔑 Sécurité (OBLIGATOIRE — pas de valeur par défaut en prod)
# ----------------------------------------
SECRET_KEY=__GENERATE_A_RANDOM_32+_CHARS_SECRET__
JWT_SECRET_KEY=__GENERATE_A_RANDOM_64+_CHARS_SECRET__
ENCRYPTION_KEY=__GENERATE_A_RANDOM_32_BYTE_KEY__

# ----------------------------------------
# 🗄️ Base de données
# ----------------------------------------
POSTGRES_PASSWORD=__SET_A_STRONG_DB_PASSWORD__
DATABASE_URL=postgresql://admin:__SET_A_STRONG_DB_PASSWORD__@database:5432/password_manager

# ----------------------------------------
# 🌐 Environnement
# ----------------------------------------
FLASK_ENV=development
ENV=development
DEBUG=true

# ----------------------------------------
# 🔒 Rate Limiting
# ----------------------------------------
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=300

# ----------------------------------------
# 📝 Logs
# ----------------------------------------
LOG_LEVEL=INFO
ENABLE_AUDIT_LOGS=true

# ----------------------------------------
# 🚨 Clé d'urgence (OBLIGATOIRE si l'endpoint de reset est exposé)
# ----------------------------------------
EMERGENCY_RESET_KEY=__GENERATE_A_RANDOM_SECRET__
