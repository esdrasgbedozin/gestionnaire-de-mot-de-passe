# Variables d'environnement pour le développement
# Copiez ce fichier vers .env et modifiez les valeurs

# Base de données
DB_HOST=localhost
DB_PORT=5432
DB_NAME=password_manager
DB_USER=admin
DB_PASSWORD=***REMOVED***

# Backend Flask
FLASK_ENV=development
FLASK_DEBUG=True
JWT_SECRET_KEY=***REMOVED***
ENCRYPTION_KEY=***REMOVED***

# Frontend
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_ENVIRONMENT=development

# Sécurité (changez ces valeurs en production)
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=3600  # 1 heure en secondes
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900  # 15 minutes en secondes