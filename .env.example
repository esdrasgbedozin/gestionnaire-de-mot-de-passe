# ========================================
# 🔐 Configuration Password Manager
# ========================================
# Copiez ce fichier en .env pour le développement

# ----------------------------------------
# 🔑 Sécurité (CHANGEZ EN PRODUCTION!)
# ----------------------------------------
SECRET_KEY=***REMOVED***-minimum-32-chars
JWT_SECRET_KEY=***REMOVED***
ENCRYPTION_KEY=***REMOVED***

# ----------------------------------------
# 🗄️ Base de données
# ----------------------------------------
DATABASE_URL=postgresql://admin:***REMOVED***@localhost:5432/password_manager
DB_PASSWORD=***REMOVED***

# ----------------------------------------
# 🌐 Environnement
# ----------------------------------------
FLASK_ENV=development
ENV=development
DEBUG=true

# ----------------------------------------
# 🔒 Rate Limiting
# ----------------------------------------
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=300

# ----------------------------------------
# 📝 Logs
# ----------------------------------------
LOG_LEVEL=INFO
ENABLE_AUDIT_LOGS=true

# ----------------------------------------
# 🚨 Clé d'urgence (optionnel)
# ----------------------------------------
EMERGENCY_RESET_KEY=***REMOVED***